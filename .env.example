# Optional but recommended. If not set, the app still works in heuristic-only mode.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4

# Optional. Semantic Scholar can work without a key for some usage levels,
# but an API key is recommended for better reliability.
SEMANTIC_SCHOLAR_API_KEY=

# Optional. OpenAlex docs currently state the API is free but requires a key.
OPENALEX_API_KEY=

# arXiv는 공개 API라 API 키 필요 없음

# App settings
DEFAULT_LANGUAGE=ko
CACHE_DIR=.cache
